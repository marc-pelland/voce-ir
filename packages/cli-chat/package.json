{
  "name": "@voce-ir/cli-chat",
  "version": "0.2.0",
  "description": "Voce IR conversational CLI. Tool-use loop, .voce/ memory, slash commands, multi-line input, readiness + drift UI. Sister to @voce-ir/mcp-server.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "voce-chat": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench:startup": "node scripts/bench-startup.mjs --runs 5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@voce-ir/mcp-server": "file:../mcp-server",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "~5.7.0",
    "vitest": "^3.2.4"
  }
}
