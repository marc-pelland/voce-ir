{
  "name": "@voce-ir/mcp-server",
  "version": "0.4.0",
  "description": "Voce IR MCP server — exposes IR tools for Claude Code and MCP clients (22 tools incl. S79 agent contract: skills/graph/doctor)",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./memory": {
      "types": "./dist/memory.d.ts",
      "default": "./dist/memory.js"
    },
    "./workflow": {
      "types": "./dist/workflow.d.ts",
      "default": "./dist/workflow.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "default": "./dist/tools.js"
    }
  },
  "bin": {
    "voce-mcp": "dist/index.js",
    "voce-mcp-server": "dist/index.js"
  },
  "license": "Apache-2.0",
  "author": "Marc Pelland",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marc-pelland/voce-ir.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://voce-ir.xyz",
  "bugs": {
    "url": "https://github.com/marc-pelland/voce-ir/issues"
  },
  "keywords": [
    "voce-ir",
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "agent",
    "tools",
    "ui-ir"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
