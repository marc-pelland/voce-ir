{
  "name": "@voce-ir/mcp-server",
  "version": "0.3.0",
  "description": "Voce IR MCP server — exposes IR tools for Claude Code and MCP clients",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./memory": {
      "types": "./dist/memory.d.ts",
      "default": "./dist/memory.js"
    },
    "./workflow": {
      "types": "./dist/workflow.d.ts",
      "default": "./dist/workflow.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "default": "./dist/tools.js"
    }
  },
  "bin": {
    "voce-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
